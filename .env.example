# Holocron — production environment
# Copy to `.env` and edit. The installer (install.sh) generates a strong
# NEO4J_PASSWORD for you on first run.

# === Required ===

# Neo4j password. Used by both Neo4j and the API. Must be set.
NEO4J_PASSWORD=change-me

# === Versioning ===

# Image tag to pull from GHCR. Pin to a release (e.g. v0.1.0) or use 'latest'.
HOLOCRON_VERSION=latest

# Image owner (GHCR org/user). Override if you forked or republished.
HOLOCRON_IMAGE_OWNER=squat-collective

# === Ports (host side) ===

UI_PORT=3333
API_PORT=8100
NEO4J_HTTP_PORT=7474
NEO4J_BOLT_PORT=7687
