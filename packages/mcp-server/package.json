{
	"name": "@squat-collective/holocron-mcp-server",
	"version": "0.1.0",
	"description": "Model Context Protocol server for the Holocron data governance platform",
	"type": "module",
	"main": "dist/index.js",
	"types": "dist/index.d.ts",
	"bin": {
		"holocron-mcp-server": "dist/index.js"
	},
	"files": [
		"dist",
		"README.md"
	],
	"repository": {
		"type": "git",
		"url": "https://github.com/squat-collective/holocron.git",
		"directory": "packages/mcp-server"
	},
	"homepage": "https://github.com/squat-collective/holocron#readme",
	"bugs": {
		"url": "https://github.com/squat-collective/holocron/issues"
	},
	"license": "MIT",
	"scripts": {
		"dev": "bun run --watch src/index.ts",
		"start": "node dist/index.js",
		"build": "bun build ./src/index.ts --outdir ./dist --target node && tsc -p tsconfig.build.json",
		"test": "bun test",
		"lint": "biome check .",
		"lint:fix": "biome check --write .",
		"format": "biome format --write .",
		"typecheck": "tsc --noEmit",
		"prepublishOnly": "bun run build"
	},
	"keywords": [
		"mcp",
		"holocron",
		"data-governance",
		"ai",
		"claude"
	],
	"dependencies": {
		"@modelcontextprotocol/sdk": "^1.0.0",
		"@squat-collective/holocron-ts": "workspace:*",
		"zod": "^3.23.0"
	},
	"devDependencies": {
		"@biomejs/biome": "^1.9.0",
		"@types/bun": "^1.1.0",
		"@types/node": "^22.0.0",
		"typescript": "^5.6.0"
	},
	"engines": {
		"node": ">=20"
	}
}
