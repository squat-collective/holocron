# Holocron Caddy config — copy to `Caddyfile` and edit.
#
# Routes:
#   /api/*  → API container (port 8000)
#   /*      → UI container (port 3000)
#
# {$HOLOCRON_DOMAIN} comes from .env. Examples:
#   HOLOCRON_DOMAIN=:80                   # bare HTTP on port 80
#   HOLOCRON_DOMAIN=holocron.example.com  # auto-HTTPS via Let's Encrypt

{$HOLOCRON_DOMAIN} {
	encode zstd gzip

	# Basic auth — uncomment and set a real user:bcrypt-hash to enable.
	# Generate the hash with:
	#   docker run --rm caddy:2 caddy hash-password --plaintext 'your-password'
	#
	# basic_auth {
	#     admin $2a$14$replace-this-with-the-output-of-hash-password
	# }

	handle /api/* {
		reverse_proxy api:8000
	}

	handle {
		reverse_proxy ui:3000
	}
}
